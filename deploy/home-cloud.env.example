APP_CONFIG=production
SECRET_KEY=replace_with_a_long_random_secret

# App runtime settings
SERVER_HOST=127.0.0.1
SERVER_PORT=5000
USE_HTTPS=false
TRUST_PROXY_HEADERS=true

# Storage and database
BASE_STORAGE_PATH=/srv/home-cloud-storage
DATABASE_URL=sqlite:////srv/home-cloud-storage/home-cloud/production.db
MAX_CONTENT_LENGTH=20000000000000
DEFAULT_TRASH_RETENTION_DAYS=30
AUTO_CLEAN_TRASH=true
TRASH_ENABLED=true
ALLOW_FOLDER_UPLOAD=true
MONITOR_TRANSFER_SPEED=true
TEMP_UPLOAD_PATH=/srv/home-cloud-storage/temp

# Gunicorn (optional)
GUNICORN_WORKERS=2
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=120
GUNICORN_GRACEFUL_TIMEOUT=30

# Load balancing (optional)
LB_INSTANCE_COUNT=4
LB_BASE_PORT=5000
LB_MAX_INSTANCES=8
