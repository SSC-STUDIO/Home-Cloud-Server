APP_CONFIG=production
# SECRET_KEY is REQUIRED - generate with: python -c 'import secrets; print(secrets.token_hex(32))'
# Must be at least 32 characters (256 bits)
SECRET_KEY=
SERVER_HOST=127.0.0.1
SERVER_PORT=5000
USE_HTTPS=false
# TRUST_PROXY_HEADERS defaults to false for security. Only enable if behind a trusted reverse proxy.
TRUST_PROXY_HEADERS=false
BASE_STORAGE_PATH=/srv/home-cloud-storage
DATABASE_URL=sqlite:////srv/home-cloud-storage/home-cloud/production.db

# Windows example
# BASE_STORAGE_PATH=D:/cloud_storage
# DATABASE_URL=sqlite:///D:/cloud_storage/home-cloud/production.db

# Optional overrides
# UPLOAD_FOLDER=
# TRASH_PATH=
# TEMP_UPLOAD_PATH=
# MAX_CONTENT_LENGTH=20000000000000
# DEFAULT_TRASH_RETENTION_DAYS=30
# AUTO_CLEAN_TRASH=true
# TRASH_ENABLED=true
# ALLOW_FOLDER_UPLOAD=true
# MONITOR_TRANSFER_SPEED=true
